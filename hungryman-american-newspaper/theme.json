{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1180px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "paper",
          "color": "#f7f3e8",
          "name": "Newsprint"
        },
        {
          "slug": "ink",
          "color": "#151515",
          "name": "Ink"
        },
        {
          "slug": "muted",
          "color": "#57534a",
          "name": "Muted Ink"
        },
        {
          "slug": "rule",
          "color": "#252525",
          "name": "Rule"
        },
        {
          "slug": "soft-rule",
          "color": "#b8b09e",
          "name": "Soft Rule"
        },
        {
          "slug": "accent",
          "color": "#8d1f1f",
          "name": "Press Red"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "Georgia, \"Times New Roman\", Times, serif",
          "name": "News Serif",
          "slug": "news-serif"
        },
        {
          "fontFamily": "\"Arial Narrow\", \"Helvetica Neue\", Arial, sans-serif",
          "name": "Condensed Sans",
          "slug": "condensed-sans"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Body",
          "slug": "body",
          "size": "1.0625rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.35rem"
        },
        {
          "name": "Masthead",
          "slug": "masthead",
          "size": "clamp(2.45rem, 9vw, 5.75rem)"
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        {
          "name": "Small",
          "slug": "40",
          "size": "0.875rem"
        },
        {
          "name": "Medium",
          "slug": "50",
          "size": "1.25rem"
        },
        {
          "name": "Large",
          "slug": "60",
          "size": "1.75rem"
        },
        {
          "name": "XL",
          "slug": "70",
          "size": "2.5rem"
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--paper)",
      "text": "var(--wp--preset--color--ink)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--news-serif)",
      "fontSize": "var(--wp--preset--font-size--body)",
      "lineHeight": "1.68"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--ink)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--accent)"
          }
        }
      },
      "button": {
        "border": {
          "radius": "0"
        },
        "color": {
          "background": "var(--wp--preset--color--ink)",
          "text": "var(--wp--preset--color--paper)"
        },
        "spacing": {
          "padding": {
            "top": "0.55rem",
            "right": "0.9rem",
            "bottom": "0.55rem",
            "left": "0.9rem"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--condensed-sans)",
          "fontWeight": "700",
          "textTransform": "uppercase",
          "letterSpacing": "0"
        }
      },
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--news-serif)",
          "fontWeight": "700",
          "lineHeight": "1.02"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--news-serif)",
          "fontWeight": "700",
          "lineHeight": "1.08"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--news-serif)",
          "fontWeight": "700",
          "lineHeight": "1.12"
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ],
  "customTemplates": []
}
