{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1120px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "bg",
          "color": "#f4f1e8",
          "name": "Journal Paper"
        },
        {
          "slug": "surface",
          "color": "#e2e2dc",
          "name": "System Gray"
        },
        {
          "slug": "surface-soft",
          "color": "#fbfaf4",
          "name": "Warm White"
        },
        {
          "slug": "text",
          "color": "#191816",
          "name": "Ink"
        },
        {
          "slug": "muted",
          "color": "#605d55",
          "name": "Ledger Gray"
        },
        {
          "slug": "line",
          "color": "#8f8d86",
          "name": "Window Line"
        },
        {
          "slug": "accent",
          "color": "#7b1f24",
          "name": "Plate Red"
        },
        {
          "slug": "accent-strong",
          "color": "#064c83",
          "name": "Desktop Blue"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "\"Baskerville\", \"Times New Roman\", Times, serif",
          "name": "Display Serif",
          "slug": "display-serif"
        },
        {
          "fontFamily": "Georgia, \"Times New Roman\", Times, serif",
          "name": "Body Serif",
          "slug": "body-serif"
        },
        {
          "fontFamily": "\"Helvetica Neue\", Helvetica, Arial, sans-serif",
          "name": "Utility Sans",
          "slug": "utility-sans"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1.0625rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.375rem"
        },
        {
          "name": "Hero",
          "slug": "hero",
          "size": "clamp(2rem, 5vw, 3.35rem)"
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        {
          "name": "4",
          "slug": "40",
          "size": "0.875rem"
        },
        {
          "name": "5",
          "slug": "50",
          "size": "1.25rem"
        },
        {
          "name": "6",
          "slug": "60",
          "size": "1.75rem"
        },
        {
          "name": "7",
          "slug": "70",
          "size": "2.5rem"
        },
        {
          "name": "8",
          "slug": "80",
          "size": "3.25rem"
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--bg)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body-serif)",
      "lineHeight": "1.78"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent-strong)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--accent)"
          }
        }
      },
      "button": {
        "border": {
          "radius": "0"
        },
        "color": {
          "background": "var(--wp--preset--color--surface)",
          "text": "var(--wp--preset--color--text)"
        },
        ":hover": {
          "color": {
            "background": "#d6d6d0"
          }
        },
        "spacing": {
          "padding": {
            "top": "0.65rem",
            "bottom": "0.65rem",
            "left": "1.1rem",
            "right": "1.1rem"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--utility-sans)",
          "fontWeight": "700",
          "textTransform": "uppercase",
          "letterSpacing": "0"
        }
      },
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display-serif)",
          "fontWeight": "700",
          "lineHeight": "1.08"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display-serif)",
          "fontWeight": "700",
          "lineHeight": "1.16"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display-serif)",
          "fontWeight": "700",
          "lineHeight": "1.18"
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ],
  "customTemplates": []
}
