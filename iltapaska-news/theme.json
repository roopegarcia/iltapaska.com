{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1220px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "bg",
          "color": "#f3f3f3",
          "name": "Paper Gray"
        },
        {
          "slug": "surface",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "ink",
          "color": "#111111",
          "name": "Ink"
        },
        {
          "slug": "muted",
          "color": "#555555",
          "name": "Muted"
        },
        {
          "slug": "line",
          "color": "#d7d7d7",
          "name": "Line"
        },
        {
          "slug": "accent",
          "color": "#e3000f",
          "name": "Tabloid Red"
        },
        {
          "slug": "accent-strong",
          "color": "#b0000c",
          "name": "Red Strong"
        },
        {
          "slug": "warning",
          "color": "#ffd400",
          "name": "Signal Yellow"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "\"Arial Black\", Impact, \"Arial Narrow Bold\", sans-serif",
          "name": "Headline Heavy",
          "slug": "headline-heavy"
        },
        {
          "fontFamily": "\"Helvetica Neue\", Helvetica, Arial, sans-serif",
          "name": "Utility Sans",
          "slug": "utility-sans"
        },
        {
          "fontFamily": "Georgia, \"Times New Roman\", Times, serif",
          "name": "Body Serif",
          "slug": "body-serif"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.3rem"
        },
        {
          "name": "Hero",
          "slug": "hero",
          "size": "clamp(2.1rem, 7vw, 4.4rem)"
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        {
          "name": "4",
          "slug": "40",
          "size": "0.875rem"
        },
        {
          "name": "5",
          "slug": "50",
          "size": "1.25rem"
        },
        {
          "name": "6",
          "slug": "60",
          "size": "1.75rem"
        },
        {
          "name": "7",
          "slug": "70",
          "size": "2.5rem"
        },
        {
          "name": "8",
          "slug": "80",
          "size": "3.5rem"
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--bg)",
      "text": "var(--wp--preset--color--ink)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body-serif)",
      "lineHeight": "1.65"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent-strong)"
        },
        ":hover": {
          "color": {
            "text": "#880009"
          }
        }
      },
      "h1": {
        "typography": {
          "fontWeight": "900",
          "fontFamily": "var(--wp--preset--font-family--headline-heavy)",
          "lineHeight": "1",
          "textTransform": "uppercase"
        }
      },
      "h2": {
        "typography": {
          "fontWeight": "900",
          "fontFamily": "var(--wp--preset--font-family--headline-heavy)",
          "lineHeight": "1.05",
          "textTransform": "uppercase"
        }
      },
      "h3": {
        "typography": {
          "fontWeight": "800",
          "fontFamily": "var(--wp--preset--font-family--headline-heavy)",
          "lineHeight": "1.1",
          "textTransform": "uppercase"
        }
      }
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "0"
        },
        "color": {
          "background": "var(--wp--preset--color--accent)",
          "text": "#ffffff"
        },
        "spacing": {
          "padding": {
            "top": "0.7rem",
            "bottom": "0.7rem",
            "left": "1.2rem",
            "right": "1.2rem"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--utility-sans)",
          "fontWeight": "800",
          "textTransform": "uppercase"
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ],
  "customTemplates": []
}
