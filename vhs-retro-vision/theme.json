{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1120px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "bg",
          "color": "#ede4d3",
          "name": "Newsprint"
        },
        {
          "slug": "surface",
          "color": "#f8f1e4",
          "name": "Paper"
        },
        {
          "slug": "surface-soft",
          "color": "#f3e9d8",
          "name": "Paper soft"
        },
        {
          "slug": "ink",
          "color": "#1f1b16",
          "name": "Ink"
        },
        {
          "slug": "ink-muted",
          "color": "#5a5248",
          "name": "Ink muted"
        },
        {
          "slug": "accent",
          "color": "#7c1f1f",
          "name": "Editorial red"
        },
        {
          "slug": "accent-strong",
          "color": "#5f1313",
          "name": "Editorial red strong"
        },
        {
          "slug": "line",
          "color": "#b5ab99",
          "name": "Rule line"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "\"Baskerville\", \"Times New Roman\", Times, serif",
          "name": "Display Serif",
          "slug": "display-serif"
        },
        {
          "fontFamily": "Georgia, \"Times New Roman\", Times, serif",
          "name": "Body Serif",
          "slug": "body-serif"
        },
        {
          "fontFamily": "\"Helvetica Neue\", Helvetica, Arial, sans-serif",
          "name": "Utility Sans",
          "slug": "utility-sans"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.25rem"
        },
        {
          "name": "Hero",
          "slug": "hero",
          "size": "clamp(2.2rem, 6vw, 4rem)"
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        {
          "name": "4",
          "slug": "40",
          "size": "0.875rem"
        },
        {
          "name": "5",
          "slug": "50",
          "size": "1.25rem"
        },
        {
          "name": "6",
          "slug": "60",
          "size": "1.75rem"
        },
        {
          "name": "7",
          "slug": "70",
          "size": "2.5rem"
        },
        {
          "name": "8",
          "slug": "80",
          "size": "3.5rem"
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--bg)",
      "text": "var(--wp--preset--color--ink)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body-serif)",
      "lineHeight": "1.7"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent-strong)"
        },
        ":hover": {
          "color": {
            "text": "#431010"
          }
        }
      },
      "h1": {
        "typography": {
          "fontWeight": "700",
          "fontFamily": "var(--wp--preset--font-family--display-serif)",
          "lineHeight": "1.05",
          "textTransform": "uppercase"
        },
        "color": {
          "text": "var(--wp--preset--color--ink)"
        }
      },
      "h2": {
        "typography": {
          "fontWeight": "700",
          "fontFamily": "var(--wp--preset--font-family--display-serif)",
          "lineHeight": "1.15",
          "textTransform": "uppercase"
        }
      },
      "h3": {
        "typography": {
          "fontWeight": "700",
          "fontFamily": "var(--wp--preset--font-family--display-serif)",
          "lineHeight": "1.2",
          "textTransform": "uppercase"
        }
      }
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "0"
        },
        "color": {
          "background": "var(--wp--preset--color--accent)",
          "text": "#ffffff"
        },
        "spacing": {
          "padding": {
            "top": "0.7rem",
            "bottom": "0.7rem",
            "left": "1.25rem",
            "right": "1.25rem"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--utility-sans)",
          "fontWeight": "700",
          "textTransform": "uppercase"
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ],
  "customTemplates": []
}
